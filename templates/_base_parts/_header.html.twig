{% set site_settings = front_data.siteSettings %}
<header class="sticky top-0 z-40 border-b border-base-300/60 bg-base-100/88 backdrop-blur-md">
    <div class="mx-auto flex w-full max-w-screen-xl items-center justify-between gap-3 px-4 py-3 sm:px-6 lg:px-8">
        <div class="min-w-0">
            <a href="{{ path('app_home') }}" class="font-headline text-lg font-black uppercase tracking-tight text-primary no-underline sm:text-xl">
                {{ site_settings and site_settings.businessName ? site_settings.businessName : 'Sandwicherie 26' }}
            </a>
            {% if site_settings and site_settings.slogan %}
                <p class="hidden truncate text-xs font-medium uppercase tracking-[0.14em] text-base-content/56 sm:block">{{ site_settings.slogan }}</p>
            {% endif %}
        </div>

        <nav class="hidden items-center gap-4 lg:flex">
            <a href="{{ path('app_home') }}" class="text-sm font-semibold text-base-content/72 no-underline transition-colors hover:text-primary">Accueil</a>
            <a href="{{ path('app_menu') }}" class="text-sm font-semibold text-base-content/72 no-underline transition-colors hover:text-primary">Carte</a>
            {% set about_page = front_data.page(constant('App\\\\Enum\\\\PageCode::ABOUT')) %}
            {% if about_page %}
                <a href="{{ path('app_page_show', {slug: about_page.slug}) }}" class="text-sm font-semibold text-base-content/72 no-underline transition-colors hover:text-primary">À propos</a>
            {% endif %}
            <a href="{{ path('app_contact') }}" class="text-sm font-semibold text-base-content/72 no-underline transition-colors hover:text-primary">Contact</a>
        </nav>

        <div class="flex items-center gap-2">
            <a href="{{ path('app_menu') }}" class="btn btn-ghost btn-sm rounded-xl px-3 lg:hidden">
                Carte
            </a>
            {% if site_settings and site_settings.phone %}
                <a href="tel:{{ site_settings.phone|replace({' ': '', '.': '', '/': ''}) }}" class="btn btn-primary btn-sm rounded-xl px-4 shadow-[0_18px_40px_-26px_rgba(30,27,25,0.38)]">
                    Appeler
                </a>
            {% endif %}
        </div>
    </div>
</header>
