<header class="sticky top-9 z-40 border-b border-white/0 bg-base-100/80 backdrop-blur-md">
    <div class="mx-auto flex w-full max-w-screen-xl flex-col gap-3 px-4 py-3 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
        {% set siteSettings = app.request is defined ? app.request.attributes.get('site_settings') : null %}

        <div>
            <a href="{{ path('app_home') }}" class="font-headline text-lg font-black uppercase tracking-tight text-primary no-underline sm:text-xl">
                {{ siteSettings and siteSettings.businessName ? siteSettings.businessName : 'Sandwicherie 26' }}
            </a>
        </div>

        <div class="flex flex-wrap items-center gap-2 sm:gap-4">
            <a href="{{ path('app_home') }}" class="text-sm font-semibold text-secondary no-underline transition-colors duration-300 hover:text-primary">
                Accueil
            </a>
            <a href="{{ path('app_menu') }}" class="text-sm font-semibold text-secondary no-underline transition-colors duration-300 hover:text-primary">
                Carte
            </a>
            <a href="{{ path('app_about') }}" class="text-sm font-semibold text-secondary no-underline transition-colors duration-300 hover:text-primary">
                A propos
            </a>
            <a href="{{ path('app_contact') }}" class="text-sm font-semibold text-secondary no-underline transition-colors duration-300 hover:text-primary">
                Contact
            </a>
            {% if siteSettings and siteSettings.phone %}
                <a href="tel:{{ siteSettings.phone|replace({' ': '', '.': '', '/': ''}) }}" class="btn btn-primary btn-sm rounded-xl px-4 shadow-[0_18px_40px_-26px_rgba(30,27,25,0.38)]">
                    Appeler
                </a>
            {% endif %}
        </div>
    </div>
</header>
