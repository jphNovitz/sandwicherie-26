{% extends 'base.html.twig' %}

{% block title %}Produits | Admin{% endblock %}

{% block body %}
    <section class="space-y-8">
        <div class="flex items-center justify-between gap-4">
            <div class="space-y-2">
                <h1>Produits</h1>
                <p>Ajout minimal d'un produit depuis l'administration.</p>
            </div>

            <a href="{{ path('admin_default') }}" class="btn btn-ghost">Retour admin</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        <div class="grid gap-8 lg:grid-cols-2">
            <div class="rounded-box border border-base-300 bg-base-100 p-6">
                <h2 class="mb-4">Ajouter un produit</h2>

                {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
                    <div class="form-control">
                        {{ form_label(form.name, null, {label_attr: {class: 'label'}}) }}
                        {{ form_widget(form.name, {attr: {class: 'input input-bordered w-full'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-control">
                        {{ form_label(form.description, null, {label_attr: {class: 'label'}}) }}
                        {{ form_widget(form.description, {attr: {class: 'textarea textarea-bordered h-32 w-full'}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="form-control">
                        {{ form_label(form.price, null, {label_attr: {class: 'label'}}) }}
                        {{ form_widget(form.price, {attr: {class: 'input input-bordered w-full'}}) }}
                        {{ form_errors(form.price) }}
                    </div>

                    <div class="form-control">
                        <label class="label cursor-pointer justify-start gap-3">
                            {{ form_widget(form.isAvailable, {attr: {class: 'checkbox checkbox-primary'}}) }}
                            <span class="label-text">Disponible</span>
                        </label>
                        {{ form_errors(form.isAvailable) }}
                    </div>

                    <button type="submit" class="btn btn-primary">Ajouter le produit</button>
                {{ form_end(form) }}
            </div>

            <div class="rounded-box border border-base-300 bg-base-100 p-6">
                <h2 class="mb-4">Produits existants</h2>

                {% if products is empty %}
                    <p>Aucun produit enregistre pour le moment.</p>
                {% else %}
                    <div class="space-y-3">
                        {% for product in products %}
                            <article class="rounded-box bg-base-200 p-4">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="space-y-1">
                                        <h3 class="mb-0 mt-0 text-lg font-semibold">{{ product.name }}</h3>
                                        <p class="mb-0 text-sm text-base-content/70">
                                            {{ product.description ?: 'Aucune description' }}
                                        </p>
                                    </div>
                                    <div class="text-right text-sm">
                                        <div class="font-semibold">{{ product.price|number_format(2, ',', ' ') }} EUR</div>
                                        <div>{{ product.isAvailable ? 'Disponible' : 'Indisponible' }}</div>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
