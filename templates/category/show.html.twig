{% extends 'base.html.twig' %}

{% block title %}{{ category.seoTitleOrDefault ?: category.name }}{% endblock %}
{% block meta_description %}{{ category.metaDescription ?: '' }}{% endblock %}

{% block body %}
    <section class="space-y-8">
        <header class="rounded-[2rem] bg-base-200 px-6 py-10 sm:px-8">
            <div class="space-y-4">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Carte</p>
                <h1 class="text-4xl font-black leading-tight sm:text-5xl">{{ category.name }}</h1>
                {% if category.description %}
                    <p class="max-w-3xl text-base leading-7 text-base-content/76">{{ category.description }}</p>
                {% endif %}
            </div>
        </header>

        <section class="space-y-6">
            {% if products is empty %}
                <div class="rounded-[1.5rem] bg-white p-6 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.45)]">
                    <p class="text-base-content/76">Aucun produit actif dans cette categorie pour le moment.</p>
                </div>
            {% else %}
                <div class="rounded-[1.75rem] bg-white p-5 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.22)] sm:p-7">
                    {% for product in products %}
                        <article class="space-y-2">
                            <div class="flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <h2 class="text-lg font-bold leading-snug sm:text-xl">{{ product.name }}</h2>
                                    {% if product.ingredients %}
                                        <p class="mt-1 text-sm leading-6 text-base-content/72 sm:text-base">{{ product.ingredients }}</p>
                                    {% endif %}
                                </div>
                                <p class="shrink-0 font-headline text-lg font-black text-accent sm:text-xl">
                                    {{ product.price|number_format(2, ',', ' ') }} EUR
                                </p>
                            </div>
                            {% if product.allergens is not empty %}
                                <p class="text-xs font-medium uppercase tracking-[0.14em] text-base-content/56 sm:text-sm">
                                    Allergènes :
                                    {% for allergen in product.allergens %}
                                        {{ allergen.name }}{% if not loop.last %}, {% endif %}
                                    {% endfor %}
                                </p>
                            {% endif %}
                        </article>
                        {% if not loop.last %}
                            <div class="my-5 h-px bg-base-300"></div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </section>
{% endblock %}
