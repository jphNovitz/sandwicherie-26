{% extends 'base.html.twig' %}

{% block title %}{{ page and page.seoTitleOrDefault ? page.seoTitleOrDefault : 'Contact | Sandwicherie 26' }}{% endblock %}
{% block meta_description %}{{ page and page.metaDescription ? page.metaDescription : 'Contactez Sandwicherie 26 pour une demande d\'information, une commande ou un besoin particulier.' }}{% endblock %}

{% block body %}
    <section class="space-y-8">
        <header class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-primary to-[#af4e24] px-5 py-12 text-primary-content shadow-[0_26px_60px_-34px_rgba(30,27,25,0.45)] sm:px-8 sm:py-14">
            <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
                <div class="space-y-4">
                    <p class="font-headline text-sm font-bold uppercase tracking-[0.2em] text-primary-content/78">Nous contacter</p>
                    <h1 class="max-w-2xl text-4xl font-black leading-tight sm:text-5xl">
                        Une demande directe, une commande, ou simplement une question.
                    </h1>
                    <p class="max-w-2xl text-base leading-7 text-primary-content/84 sm:text-lg">
                        Utilise le formulaire pour nous ecrire. Le ton reste simple, la reponse utile, et l'experience
                        visuelle garde la chaleur editoriale du design system.
                    </p>
                </div>
                <div class="rounded-[1.5rem] bg-white/12 p-5 backdrop-blur-sm">
                    <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-primary-content/70">Disponibilite</p>
                    <p class="mt-3 text-3xl font-black">Rapide</p>
                    <p class="mt-2 text-sm leading-6 text-primary-content/78">
                        Pour une information produit, une demande de commande ou un besoin particulier.
                    </p>
                </div>
            </div>
        </header>

        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
            <aside class="space-y-6 rounded-[1.75rem] bg-base-200 p-6 sm:p-8">
                <div class="space-y-3">
                    <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Coordonnees</p>
                    <h2 class="text-3xl font-black leading-tight">Venir facilement, ecrire simplement.</h2>
                    <p class="text-base leading-7 text-base-content/76">
                        La carte reste utile et sobre. Si la localisation n’est pas encore renseignee, la page reste
                        pleinement fonctionnelle avec les autres informations.
                    </p>
                </div>

                <div class="space-y-4 text-sm leading-6 text-base-content/76">
                    {% if site_settings %}
                        <div>
                            <p class="font-semibold text-base-content">Adresse</p>
                            <p>{{ site_settings.fullAddress ?: site_settings.shortAddress ?: 'Adresse a renseigner.' }}</p>
                        </div>
                        <div class="grid gap-4 sm:grid-cols-2">
                            <div>
                                <p class="font-semibold text-base-content">Telephone</p>
                                <p>{{ site_settings.phone ?: 'Non renseigne' }}</p>
                            </div>
                            <div>
                                <p class="font-semibold text-base-content">Email</p>
                                <p>{{ site_settings.email ?: 'Non renseigne' }}</p>
                            </div>
                        </div>
                        {% if site_settings.whatsapp %}
                            <div>
                                <p class="font-semibold text-base-content">WhatsApp</p>
                                <p>{{ site_settings.whatsapp }}</p>
                            </div>
                        {% endif %}
                    {% else %}
                        <p>Les informations du site ne sont pas encore renseignees.</p>
                    {% endif %}
                </div>

                {% if site_settings and (site_settings.phone or site_settings.whatsapp) %}
                    <div class="space-y-3">
                        <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Commander</p>
                        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                            {% if site_settings.phone %}
                                <a href="tel:{{ site_settings.phone|replace({' ': '', '.': '', '/': ''}) }}" class="btn btn-primary rounded-xl">
                                    Commander par telephone
                                </a>
                            {% endif %}
                            {% if site_settings.whatsapp %}
                                <a href="https://wa.me/{{ site_settings.whatsapp|replace({' ': '', '.': '', '/': '', '+': ''}) }}" target="_blank" rel="noreferrer" class="btn btn-outline btn-primary rounded-xl">
                                    Commander via WhatsApp
                                </a>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}

                {% if itinerary_url %}
                    <a href="{{ itinerary_url }}" target="_blank" rel="noreferrer" class="btn btn-primary w-full rounded-xl sm:w-auto">
                        Itineraire
                    </a>
                {% endif %}

                {% if opening_hours is not empty %}
                    <div class="space-y-3">
                        <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Horaires</p>
                        <div class="space-y-2 text-sm leading-6 text-base-content/76">
                            {% for opening_hour in opening_hours %}
                                <div class="flex items-start justify-between gap-4">
                                    <span class="font-medium text-base-content">
                                        {{ {
                                            monday: 'Lundi',
                                            tuesday: 'Mardi',
                                            wednesday: 'Mercredi',
                                            thursday: 'Jeudi',
                                            friday: 'Vendredi',
                                            saturday: 'Samedi',
                                            sunday: 'Dimanche'
                                        }[opening_hour.dayOfWeek.value] }}
                                    </span>
                                    <span class="text-right">
                                        {% if opening_hour.isClosed %}
                                            Ferme
                                        {% else %}
                                            {{ opening_hour.firstOpeningAt ? opening_hour.firstOpeningAt|date('H:i') : '' }}
                                            {% if opening_hour.firstClosingAt %}- {{ opening_hour.firstClosingAt|date('H:i') }}{% endif %}
                                            {% if opening_hour.secondOpeningAt and opening_hour.secondClosingAt %}
                                                <br>{{ opening_hour.secondOpeningAt|date('H:i') }} - {{ opening_hour.secondClosingAt|date('H:i') }}
                                            {% endif %}
                                        {% endif %}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {% if social_links is not empty %}
                    <div class="space-y-3">
                        <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Reseaux sociaux</p>
                        <div class="flex flex-wrap gap-3">
                            {% for social_link in social_links %}
                                <a href="{{ social_link.url }}" target="_blank" rel="noreferrer" class="btn btn-sm rounded-xl border-0 bg-white text-base-content shadow-none hover:bg-base-100">
                                    {{ social_link.label ?: social_link.type.value|title }}
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </aside>

            <div class="space-y-8">
                <section class="rounded-[1.75rem] bg-white p-6 shadow-[0_24px_50px_-40px_rgba(30,27,25,0.42)] sm:p-8">
                    {% if contact_map %}
                        <div class="space-y-4">
                            <div class="flex items-center justify-between gap-4">
                                <div>
                                    <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Carte</p>
                                    <p class="text-sm text-base-content/68">Localisation du commerce sur OpenStreetMap.</p>
                                </div>
                                {% if itinerary_url %}
                                    <a href="{{ itinerary_url }}" target="_blank" rel="noreferrer" class="btn btn-outline btn-primary btn-sm rounded-xl">
                                        Itineraire
                                    </a>
                                {% endif %}
                            </div>
                            {{ ux_map(contact_map, { class: 'h-80 w-full overflow-hidden rounded-[1.25rem]' }) }}
                        </div>
                    {% else %}
                        <div class="rounded-[1.25rem] bg-base-200 p-6 text-sm leading-6 text-base-content/72">
                            La carte apparaitra ici des que la latitude et la longitude du commerce seront renseignees.
                        </div>
                    {% endif %}
                </section>

                <div class="rounded-[1.75rem] bg-white p-6 shadow-[0_24px_50px_-40px_rgba(30,27,25,0.42)] sm:p-8">
                {% for message in app.flashes('success') %}
                    <div class="alert mb-6 border-0 bg-secondary/12 text-secondary shadow-none">
                        <span>{{ message }}</span>
                    </div>
                {% endfor %}

                {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
                    <div class="form-control">
                        {{ form_label(form.name, 'Nom', {label_attr: {class: 'mb-2 text-sm font-semibold uppercase tracking-[0.14em] text-base-content/68'}}) }}
                        {{ form_widget(form.name, {attr: {class: 'input w-full rounded-xl border-0 bg-base-200 shadow-none focus:outline-none focus:ring-2 focus:ring-primary/20'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-control">
                        {{ form_label(form.email, 'Email', {label_attr: {class: 'mb-2 text-sm font-semibold uppercase tracking-[0.14em] text-base-content/68'}}) }}
                        {{ form_widget(form.email, {attr: {class: 'input w-full rounded-xl border-0 bg-base-200 shadow-none focus:outline-none focus:ring-2 focus:ring-primary/20'}}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="form-control">
                        {{ form_label(form.phone, 'Telephone', {label_attr: {class: 'mb-2 text-sm font-semibold uppercase tracking-[0.14em] text-base-content/68'}}) }}
                        {{ form_widget(form.phone, {attr: {class: 'input w-full rounded-xl border-0 bg-base-200 shadow-none focus:outline-none focus:ring-2 focus:ring-primary/20'}}) }}
                        {{ form_errors(form.phone) }}
                    </div>

                    <div class="form-control">
                        {{ form_label(form.message, 'Message', {label_attr: {class: 'mb-2 text-sm font-semibold uppercase tracking-[0.14em] text-base-content/68'}}) }}
                        {{ form_widget(form.message, {attr: {class: 'textarea min-h-40 w-full rounded-xl border-0 bg-base-200 shadow-none focus:outline-none focus:ring-2 focus:ring-primary/20'}}) }}
                        {{ form_errors(form.message) }}
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-sm leading-6 text-base-content/62">Chaque message est lu puis traite localement.</p>
                        <button type="submit" class="btn btn-primary w-full rounded-xl px-6 sm:w-auto">
                            Envoyer
                        </button>
                    </div>
                {{ form_end(form) }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
