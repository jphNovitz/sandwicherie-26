{% extends 'base.html.twig' %}

{% block title %}{{ page and page.seoTitleOrDefault ? page.seoTitleOrDefault : 'Carte | ' ~ (front_data.siteSettings and front_data.siteSettings.businessName ? front_data.siteSettings.businessName : 'Sandwicherie') }}{% endblock %}
{% block meta_description %}{{ page and page.metaDescription ? page.metaDescription : 'Consultez la carte, les categories et les produits disponibles.' }}{% endblock %}

{% block body %}
    <section class="space-y-8">
        <header class="rounded-[2rem] bg-base-200 px-5 py-10 sm:px-8 sm:py-12">
            <div class="max-w-3xl space-y-4">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Carte</p>
                <h1 class="text-4xl font-black leading-tight sm:text-5xl">{{ page and page.title ? page.title : 'Notre carte' }}</h1>
                {% if page and page.introduction %}
                    <p class="text-base leading-7 text-base-content/76 sm:text-lg">{{ page.introduction }}</p>
                {% else %}
                    <p class="text-base leading-7 text-base-content/76 sm:text-lg">Une lecture simple, mobile-first, avec l'essentiel en priorite : nom, prix, ingredients et allergenes.</p>
                {% endif %}
            </div>
        </header>

        {% if menu_categories is not empty %}
            <nav class="sticky top-20 z-20 overflow-x-auto rounded-[1.5rem] bg-base-100/90 p-3 shadow-[0_18px_36px_-32px_rgba(30,27,25,0.4)] backdrop-blur">
                <div class="flex min-w-max gap-2">
                    {% for item in menu_categories %}
                        <a href="#{{ item.category.slug }}" class="btn btn-sm rounded-xl border-0 bg-base-200 text-base-content shadow-none hover:bg-base-300">
                            {{ item.category.name }}
                        </a>
                    {% endfor %}
                </div>
            </nav>
        {% endif %}

        {% if menu_categories is empty %}
            <div class="rounded-[1.5rem] bg-white p-6 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.45)]">
                <p class="text-base-content/76">Aucune categorie avec produits actifs n'est disponible pour le moment.</p>
            </div>
        {% else %}
            <div class="space-y-10">
                {% for item in menu_categories %}
                    <section id="{{ item.category.slug }}" class="scroll-mt-28 space-y-5 rounded-[1.75rem] bg-white p-5 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.22)] sm:p-7">
                        <div class="space-y-3 border-b border-base-300 pb-4">
                            <div class="flex items-center justify-between gap-4">
                                <div>
                                    <h2 class="text-2xl font-black sm:text-3xl">{{ item.category.name }}</h2>
                                    {% if item.category.description %}
                                        <p class="mt-2 max-w-3xl text-sm leading-6 text-base-content/72 sm:text-base">{{ item.category.description }}</p>
                                    {% endif %}
                                </div>
                                <a href="{{ path('app_category_show', {slug: item.category.slug}) }}" class="hidden text-sm font-semibold text-primary no-underline hover:text-accent sm:inline">
                                    Voir la categorie
                                </a>
                            </div>
                        </div>

                        <div class="space-y-5">
                            {% for product in item.products %}
                                <article class="space-y-2">
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="min-w-0">
                                            <h3 class="text-lg font-bold leading-snug sm:text-xl">{{ product.name }}</h3>
                                            {% if product.ingredients %}
                                                <p class="mt-1 text-sm leading-6 text-base-content/72 sm:text-base">{{ product.ingredients }}</p>
                                            {% endif %}
                                        </div>
                                        <p class="shrink-0 font-headline text-lg font-black text-accent sm:text-xl">
                                            {{ product.price|number_format(2, ',', ' ') }} EUR
                                        </p>
                                    </div>
                                    {% if product.allergens is not empty %}
                                        <p class="text-xs font-medium uppercase tracking-[0.14em] text-base-content/56 sm:text-sm">
                                            Allergènes :
                                            {% for allergen in product.allergens %}
                                                {{ allergen.name }}{% if not loop.last %}, {% endif %}
                                            {% endfor %}
                                        </p>
                                    {% endif %}
                                </article>
                                {% if not loop.last %}
                                    <div class="h-px bg-base-300"></div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </section>
                {% endfor %}
            </div>
        {% endif %}
    </section>
{% endblock %}
