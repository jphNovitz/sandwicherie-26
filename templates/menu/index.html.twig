{% extends 'base.html.twig' %}

{% block title %}{{ page and page.seoTitleOrDefault ? page.seoTitleOrDefault : 'Carte | Sandwicherie 26' }}{% endblock %}
{% block meta_description %}{{ page and page.metaDescription ? page.metaDescription : 'Consultez la carte et les produits disponibles du moment.' }}{% endblock %}

{% block body %}
    <section class="space-y-8">
        <header class="rounded-[2rem] bg-base-200 px-6 py-10 sm:px-8">
            <div class="space-y-4">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Carte</p>
                <h1 class="text-4xl font-black leading-tight sm:text-5xl">{{ page and page.title ? page.title : 'Notre carte' }}</h1>
                {% if page and page.introduction %}
                    <p class="max-w-3xl text-base leading-7 text-base-content/76">{{ page.introduction }}</p>
                {% else %}
                    <p class="max-w-3xl text-base leading-7 text-base-content/76">Une lecture mobile simple, avec le nom, le prix, les ingredients et les allergenes en priorite.</p>
                {% endif %}
            </div>
        </header>

        {% if menu_categories is empty %}
            <div class="rounded-[1.5rem] bg-white p-6 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.45)]">
                <p class="text-base-content/76">Aucune categorie avec produits actifs n'est disponible pour le moment.</p>
            </div>
        {% else %}
            <nav class="overflow-x-auto rounded-[1.5rem] bg-base-100 p-3 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.2)]">
                <div class="flex min-w-max gap-2">
                    {% for item in menu_categories %}
                        <a href="#{{ item.category.slug }}" class="btn btn-sm rounded-xl border-0 bg-base-200 shadow-none hover:bg-base-300">
                            {{ item.category.name }}
                        </a>
                    {% endfor %}
                </div>
            </nav>

            <div class="space-y-8">
                {% for item in menu_categories %}
                    <section id="{{ item.category.slug }}" class="scroll-mt-24 rounded-[1.75rem] bg-white p-5 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.22)] sm:p-7">
                        <div class="space-y-3 border-b border-base-300 pb-4">
                            <h2 class="text-2xl font-black sm:text-3xl">{{ item.category.name }}</h2>
                            {% if item.category.description %}
                                <p class="max-w-3xl text-sm leading-6 text-base-content/72 sm:text-base">{{ item.category.description }}</p>
                            {% endif %}
                        </div>

                        <div class="space-y-5 pt-5">
                            {% for product in item.products %}
                                <article class="space-y-2">
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="min-w-0">
                                            <h3 class="text-lg font-bold leading-snug sm:text-xl">{{ product.name }}</h3>
                                            {% if product.ingredients %}
                                                <p class="mt-1 text-sm leading-6 text-base-content/72 sm:text-base">{{ product.ingredients }}</p>
                                            {% endif %}
                                        </div>
                                        <p class="shrink-0 font-headline text-lg font-black text-accent sm:text-xl">
                                            {{ product.price|number_format(2, ',', ' ') }} EUR
                                        </p>
                                    </div>
                                    {% if product.allergens is not empty %}
                                        <p class="text-xs font-medium uppercase tracking-[0.14em] text-base-content/56 sm:text-sm">
                                            Allergenes :
                                            {% for allergen in product.allergens %}
                                                {{ allergen.name }}{% if not loop.last %}, {% endif %}
                                            {% endfor %}
                                        </p>
                                    {% endif %}
                                </article>
                                {% if not loop.last %}
                                    <div class="my-5 h-px bg-base-300"></div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </section>
                {% endfor %}
            </div>
        {% endif %}
    </section>
{% endblock %}
