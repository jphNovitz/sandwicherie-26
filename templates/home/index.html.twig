{% extends 'base.html.twig' %}

{% block title %}Accueil | Sandwicherie 26{% endblock %}
{% block meta_description %}Decouvrez Sandwicherie 26, ses produits disponibles et une offre de quartier simple pour la pause dejeuner.{% endblock %}

{% block body %}
    <section class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-primary to-[#af4e24] px-5 py-12 text-primary-content shadow-[0_26px_60px_-34px_rgba(30,27,25,0.45)] sm:px-8 sm:py-16 lg:px-12">
        <div class="grid gap-10 lg:grid-cols-[1.25fr_0.75fr] lg:items-end">
            <div class="space-y-6">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.22em] text-primary-content/78">Gourmet editorial</p>
                <div class="max-w-3xl space-y-4">
                    <h1 class="max-w-2xl text-4xl font-black leading-tight sm:text-5xl lg:text-6xl">
                        Des sandwiches de quartier servis avec chaleur et relief.
                    </h1>
                    <p class="max-w-2xl text-base leading-7 text-primary-content/84 sm:text-lg">
                        Une offre lisible, des produits disponibles sans friction et une ambiance plus proche d'un comptoir
                        artisanal que d'une interface standardisee.
                    </p>
                </div>
                <div class="flex flex-col gap-3 sm:flex-row">
                    <a href="{{ path('app_contact') }}" class="btn btn-neutral rounded-xl border-0 px-6 shadow-none">
                        Nous contacter
                    </a>
                    <a href="#menu" class="btn rounded-xl border-white/18 bg-white/10 px-6 text-primary-content shadow-none backdrop-blur-sm hover:bg-white/16">
                        Voir la selection
                    </a>
                </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
                <div class="rounded-[1.5rem] bg-white/12 p-5 backdrop-blur-sm">
                    <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-primary-content/70">Service</p>
                    <p class="mt-3 text-3xl font-black">Rapide</p>
                    <p class="mt-2 text-sm leading-6 text-primary-content/78">Des commandes simples a passer et une preparation pensee pour le temps de midi.</p>
                </div>
                <div class="rounded-[1.5rem] bg-white/12 p-5 backdrop-blur-sm">
                    <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-primary-content/70">Cuisine</p>
                    <p class="mt-3 text-3xl font-black">Genereuse</p>
                    <p class="mt-2 text-sm leading-6 text-primary-content/78">Une carte claire, des essentiels bien executes et un ton plus chaleureux que demonstratif.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-12 sm:py-16">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <div class="space-y-3">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Le comptoir</p>
                <h2 class="text-3xl font-black leading-tight text-base-content sm:text-4xl">
                    Une sandwicherie de quartier, pensee comme une carte editoriale.
                </h2>
            </div>
            <div class="space-y-4 rounded-[1.75rem] bg-base-200 p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] sm:p-8">
                <p class="text-base leading-7 text-base-content/78">
                    Nous preparons chaque jour une offre simple, genereuse et accessible, pensee pour les pauses dejeuner
                    et les petites faims.
                </p>
                <p class="text-base leading-7 text-base-content/78">
                    Les sections s'appuient sur des fonds creme, terracotta et olive pour faire ressortir les contenus
                    sans recourir a des bordures dures ni a des cartes trop techniques.
                </p>
                <div class="h-1 w-20 rounded-full bg-accent/35"></div>
                <p class="text-sm font-medium uppercase tracking-[0.16em] text-accent">
                    Simplicite, rythme et lisibilite.
                </p>
            </div>
        </div>
    </section>

    <section id="menu" class="rounded-[2rem] bg-base-300/80 px-5 py-10 sm:px-8 sm:py-12">
        <div class="space-y-8">
            <div class="max-w-3xl space-y-3">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Selection du jour</p>
                <h2 class="text-3xl font-black leading-tight sm:text-4xl">Notre selection</h2>
                <p class="max-w-2xl text-base leading-7 text-base-content/76">
                    Quelques produits disponibles a la commande, presentes sur des couches chaudes pour conserver le
                    relief du design system.
                </p>
            </div>

            {% if products is empty %}
                <div class="rounded-[1.5rem] bg-white p-6 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.45)]">
                    <p class="text-base-content/76">Aucun produit disponible pour le moment.</p>
                </div>
            {% else %}
                <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                    {% for product in products %}
                        <article class="card rounded-[1.5rem] bg-white shadow-[0_24px_50px_-40px_rgba(30,27,25,0.42)]">
                            <div class="card-body gap-4 p-6">
                                <div class="space-y-2">
                                    <p class="font-headline text-xs font-bold uppercase tracking-[0.16em] text-secondary">Disponible</p>
                                    <h3 class="card-title text-2xl font-extrabold">{{ product.name }}</h3>
                                </div>
                                <p class="text-base leading-7 text-base-content/74">{{ product.description ?: 'Description a venir.' }}</p>
                                <div class="card-actions mt-2 flex-col items-start gap-3 sm:flex-row sm:items-center sm:justify-between">
                                    <span class="font-headline text-xl font-black text-accent">
                                        {{ product.price|number_format(2, ',', ' ') }} EUR
                                    </span>
                                    <span class="badge border-0 bg-secondary/14 px-4 py-3 text-secondary">
                                        Frais du jour
                                    </span>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>

    <section id="contact" class="py-10 sm:py-12">
        <div class="grid gap-6 rounded-[2rem] bg-gradient-to-r from-base-200 to-base-300 px-5 py-8 sm:px-8 sm:py-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
            <div class="space-y-4">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Contact</p>
                <h2 class="text-3xl font-black leading-tight sm:text-4xl">Un besoin particulier ou une commande a preparer ?</h2>
                <p class="max-w-2xl text-base leading-7 text-base-content/76">
                    Contactez-nous pour une commande, une demande d'information ou pour preparer la suite du contenu du site.
                </p>
            </div>
            <div class="flex flex-col gap-3 lg:items-end">
                <a href="{{ path('app_contact') }}" class="btn btn-primary w-full rounded-xl px-6 sm:w-auto">
                    Envoyer un message
                </a>
                <p class="text-sm text-base-content/64">Reponse rapide, ton direct, informations utiles.</p>
            </div>
        </div>
    </section>
{% endblock %}
