{% extends 'base.html.twig' %}

{% block title %}{{ page and page.seoTitleOrDefault ? page.seoTitleOrDefault : 'Accueil | Sandwicherie 26' }}{% endblock %}
{% block meta_description %}{{ page and page.metaDescription ? page.metaDescription : 'Decouvrez Sandwicherie 26, ses produits disponibles et une offre de quartier simple pour la pause dejeuner.' }}{% endblock %}

{% block body %}
    {% set heroImagePath = site_settings and site_settings.heroImage ? 'images/siteConfig/' ~ site_settings.heroImage : null %}
    <section class="hero overflow-hidden rounded-[2rem] bg-gradient-to-br from-[#af4e24] to-primary/20 px-5 py-12 text-primary-content shadow-[0_26px_60px_-34px_rgba(30,27,25,0.45)] sm:px-8 sm:py-16 lg:px-12">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] lg:items-center">
            <div class="min-w-0 space-y-4">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.22em] text-primary-content/78">Gourmet editorial</p>
                <div class="max-w-3xl space-y-4">
                    <h1 class="max-w-2xl text-3xl font-black leading-tight tracking-tighter sm:text-4xl lg:text-5xl">
                        Des sandwiches de quartier servis avec chaleur et relief.
                    </h1>
                    <p class="max-w-2xl text-base leading-7 text-primary-content/84 sm:text-lg">
                        Une offre lisible, des produits disponibles sans friction et une ambiance plus proche d'un comptoir
                        artisanal que d'une interface standardisee.
                    </p>
                </div>
                <div class="flex flex-col gap-3 sm:flex-row">
                    <a href="{{ path('app_menu') }}" class="btn btn-neutral rounded-xl border-0 px-6 shadow-none">
                        Voir la carte
                    </a>
                    {% if site_settings and site_settings.phone %}
                        <a href="tel:{{ site_settings.phone|replace({' ': '', '.': '', '/': ''}) }}" class="btn rounded-xl border-secondary/18 bg-secondary/10 px-6 text-secondary-content shadow-none backdrop-blur-sm hover:bg-secondary/16">
                            Commander par telephone
                        </a>
                    {% elseif site_settings and site_settings.whatsapp %}
                        <a href="https://wa.me/{{ site_settings.whatsapp|replace({' ': '', '.': '', '/': '', '+': ''}) }}" target="_blank" rel="noreferrer" class="btn rounded-xl border-white/18 bg-white/10 px-6 text-primary-content shadow-none backdrop-blur-sm hover:bg-white/16">
                            Commander via WhatsApp
                        </a>
                    {% endif %}
                </div>
            </div>

                {% if heroImagePath %}
                <div class="min-w-0">
                    <img src="{{ asset(heroImagePath) }}"
                        alt="Visuel principal de l'enseigne {{site_settings.businessName}}"
                        class="block max-h-72 h-auto w-full max-w-full rounded-2xl object-cover shadow-2xl lg:max-h-none">
                </div>

                    {#<div class="relative overflow-hidden rounded-[1.75rem] border border-white/18 bg-white/10 shadow-[0_24px_60px_-34px_rgba(30,27,25,0.5)]">
                        <img
                            src="{{ asset(site_settings.heroImage) }}"
                            alt="Visuel principal de l'enseigne"
                            class="max-w-sm rounded-lg shadow-2xl">
                    </div>#}
                
                {% endif %}

        </div>
    </section>

    <section id="menu" class="rounded-[2rem] bg-base-300/80 px-5 py-10 sm:px-8 sm:py-12">
        <div class="space-y-8">
            <div class="max-w-3xl space-y-3">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Selection du jour</p>
                <h2 class="text-3xl font-black leading-tight sm:text-4xl">Notre selection</h2>
                <p class="w-full text-base leading-7 text-base-content/76">
                    Une selection pilotee depuis les mises en avant de l’accueil pour faire remonter les produits et categories prioritaires.
                </p>
            </div>

            {% if featured_items is empty %}
                <div class="rounded-[1.5rem] bg-white p-6 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.45)]">
                    <p class="text-base-content/76">Aucune mise en avant active pour le moment.</p>
                </div>
            {% else %}
                <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                    {% for featuredItem in featured_items %}
                        <twig:FeaturedItemCard :featuredItem="featuredItem" />
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>

    <section class="py-12 sm:py-16">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <div class="space-y-3">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Le comptoir</p>
                <h2 class="text-3xl font-black leading-tight text-base-content sm:text-4xl">
                    Une sandwicherie de quartier, pensee comme une carte editoriale.
                </h2>
            </div>
            <div class="space-y-4 rounded-[1.75rem] bg-base-200 p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] sm:p-8">
                <p class="text-base leading-7 text-base-content/78">
                    Nous preparons chaque jour une offre simple, genereuse et accessible, pensee pour les pauses dejeuner
                    et les petites faims.
                </p>
                <p class="text-base leading-7 text-base-content/78">
                    Les sections s'appuient sur des fonds creme, terracotta et olive pour faire ressortir les contenus
                    sans recourir a des bordures dures ni a des cartes trop techniques.
                </p>
                <div class="h-1 w-20 rounded-full bg-accent/35"></div>
                <p class="text-sm font-medium uppercase tracking-[0.16em] text-accent">
                    Simplicite, rythme et lisibilite.
                </p>
            </div>
        </div>
    </section>

    <section class="py-12 sm:py-16">
        <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:gap-12">
            <div class="rounded-[2rem] bg-white p-6 shadow-[0_24px_50px_-40px_rgba(30,27,25,0.42)] sm:p-8">
                <div class="space-y-6">
                    <div class="space-y-3">
                        <h2 class="font-headline flex items-center gap-3 text-3xl font-black leading-tight text-base-content sm:text-4xl">
                            {{ ux_icon('mdi:clock-outline', { class: 'h-8 w-8 text-primary shrink-0' })|raw }}
                            Nos horaires
                        </h2>
                    </div>

                    {% if opening_hours is not empty %}
                        <div class="space-y-2">
                            {% for opening_hour in opening_hours %}
                                <div class="flex items-start justify-between gap-4 border-b border-base-300/70 py-3 last:border-b-0">
                                    <span class="font-medium text-base-content">
                                        {{ {
                                            monday: 'Lundi',
                                            tuesday: 'Mardi',
                                            wednesday: 'Mercredi',
                                            thursday: 'Jeudi',
                                            friday: 'Vendredi',
                                            saturday: 'Samedi',
                                            sunday: 'Dimanche'
                                        }[opening_hour.dayOfWeek.value] }}
                                    </span>
                                    <span class="text-right text-sm leading-6 text-base-content/72">
                                        {% if opening_hour.isClosed %}
                                            <span class="font-semibold italic text-primary">Ferme</span>
                                        {% else %}
                                            {{ opening_hour.firstOpeningAt ? opening_hour.firstOpeningAt|date('H:i') : '' }}
                                            {% if opening_hour.firstClosingAt %}- {{ opening_hour.firstClosingAt|date('H:i') }}{% endif %}
                                            {% if opening_hour.secondOpeningAt and opening_hour.secondClosingAt %}
                                                <br>{{ opening_hour.secondOpeningAt|date('H:i') }} - {{ opening_hour.secondClosingAt|date('H:i') }}
                                            {% endif %}
                                        {% endif %}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="rounded-[1.25rem] bg-base-200 p-5 text-sm leading-6 text-base-content/72">
                            Les horaires seront affiches ici des qu’ils seront renseignes dans l’administration.
                        </div>
                    {% endif %}

                    <div class="flex flex-col gap-3 sm:flex-row">
                        <a href="{{ path('app_contact') }}" class="link link-hover text-sm font-bold text-primary sm:text-base">
                            Nous contacter pour une réservation
                        </a>
                    </div>
                </div>
            </div>

            <div class="rounded-[2rem] bg-base-200 p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] sm:p-5">
                <div class="space-y-4">
                    <div class="px-2 pt-2">
                        <h2 class="font-headline flex items-center gap-3 text-3xl font-black leading-tight text-base-content sm:text-4xl">
                            {{ ux_icon('mdi:map-marker-outline', { class: 'h-8 w-8 text-primary shrink-0' })|raw }}
                            Nous contacter
                        </h2>
                        {% if site_settings and (site_settings.fullAddress or site_settings.shortAddress) %}
                            <p class="mt-4 text-base leading-7 text-base-content/76">
                                {{ site_settings.fullAddress ?: site_settings.shortAddress }}
                            </p>
                        {% endif %}
                    </div>

                    {% if contact_map %}
                        <div class="relative z-0 overflow-hidden rounded-[1.5rem] bg-white shadow-[0_24px_50px_-40px_rgba(30,27,25,0.42)]">
                            {{ ux_map(contact_map, { class: 'h-72 w-full sm:h-80 lg:h-[26rem]' }) }}
                        </div>
                    {% else %}
                        <div class="rounded-[1.5rem] bg-white p-6 text-sm leading-6 text-base-content/72 shadow-[0_24px_50px_-40px_rgba(30,27,25,0.42)]">
                            La carte apparaitra ici des que la latitude et la longitude du commerce seront renseignees.
                        </div>
                    {% endif %}

                    {% if itinerary_url %}
                        <div class="px-2 pb-2">
                            <a href="{{ itinerary_url }}" target="_blank" rel="noreferrer" class="btn btn-primary rounded-xl px-6">
                                Ouvrir dans Google Maps
                                {{ ux_icon('mdi:open-in-new', { class: 'h-5 w-5' })|raw }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="py-10 sm:py-12">
        <div class="rounded-[2rem] bg-gradient-to-r from-base-200 to-base-300 px-5 py-8 sm:px-8 sm:py-10">
            <div class="space-y-6">
                <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">Contact</p>
                <h2 class="text-3xl font-black leading-tight sm:text-4xl">Un besoin particulier ou une commande a preparer ?</h2>
                <p class="w-full text-base leading-7 text-base-content/76">
                    Pour commander, utilise le vrai canal disponible : telephone, WhatsApp ou contact direct selon les informations renseignees.
                </p>

                <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
                    {% if site_settings and site_settings.phone %}
                        <a href="tel:{{ site_settings.phone|replace({' ': '', '.': '', '/': ''}) }}" class="btn btn-primary w-full rounded-xl px-6 sm:w-auto">
                            Commander par telephone
                        </a>
                    {% elseif site_settings and site_settings.whatsapp %}
                        <a href="https://wa.me/{{ site_settings.whatsapp|replace({' ': '', '.': '', '/': '', '+': ''}) }}" target="_blank" rel="noreferrer" class="btn btn-primary w-full rounded-xl px-6 sm:w-auto">
                            Commander via WhatsApp
                        </a>
                    {% endif %}

                    {% if site_settings and site_settings.email %}
                        <a href="mailto:{{ site_settings.email }}" class="inline-flex w-full items-center justify-center rounded-xl border border-primary/28 px-6 py-3 font-semibold text-primary transition hover:bg-transparent hover:underline sm:w-auto">
                            Nous contacter par email
                        </a>
                    {% elseif (not site_settings or (not site_settings.phone and not site_settings.whatsapp)) %}
                        <a href="{{ path('app_contact') }}" class="inline-flex w-full items-center justify-center rounded-xl border border-primary/28 px-6 py-3 font-semibold text-primary transition hover:bg-transparent hover:underline sm:w-auto">
                            Nous contacter par email
                        </a>
                    {% endif %}
                </div>

                <p class="text-sm text-base-content/64">Aucun faux tunnel de commande, uniquement un contact direct et utile.</p>
            </div>
        </div>
    </section>
{% endblock %}
