{% extends 'base.html.twig' %}

{% block title %}{{ page.seoTitleOrDefault ?: 'Sandwicherie 26' }}{% endblock %}
{% block meta_description %}{{ page.metaDescription ?: '' }}{% endblock %}

{% block body %}
    <section class="mx-auto max-w-4xl space-y-8">
        <header class="space-y-4 rounded-[2rem] bg-base-200 px-6 py-10 sm:px-8">
            <p class="font-headline text-sm font-bold uppercase tracking-[0.18em] text-secondary">{{ page.code.value == 'about' ? 'A propos' : page.code.value }}</p>
            <h1 class="text-4xl font-black leading-tight sm:text-5xl">{{ page.title }}</h1>
            {% if page.introduction %}
                <p class="max-w-3xl text-base leading-7 text-base-content/76">{{ page.introduction }}</p>
            {% endif %}
        </header>

        {% if page.content %}
            <article class="prose max-w-none rounded-[2rem] bg-white p-6 shadow-[0_24px_50px_-40px_rgba(30,27,25,0.42)] sm:p-8">
                {{ page.content|nl2br }}
            </article>
        {% endif %}

        {% if page.code.value == 'about' and about_highlights is not empty %}
            <section class="space-y-5">
                <h2 class="text-2xl font-black sm:text-3xl">Pourquoi venir chez nous</h2>
                <div class="grid gap-5 md:grid-cols-2">
                    {% for highlight in about_highlights %}
                        <article class="rounded-[1.5rem] bg-white p-6 shadow-[0_20px_45px_-38px_rgba(30,27,25,0.22)]">
                            <h3 class="text-xl font-bold">{{ highlight.title }}</h3>
                            <p class="mt-3 text-base leading-7 text-base-content/74">{{ highlight.shortText }}</p>
                        </article>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {% if page.code.value == 'about' and gallery_images is not empty %}
            <section class="space-y-5">
                <h2 class="text-2xl font-black sm:text-3xl">Quelques images</h2>
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    {% for image in gallery_images %}
                        <figure class="overflow-hidden rounded-[1.5rem] bg-base-200">
                            <img src="{{ image.image }}" alt="{{ image.altText ?: 'Galerie ' ~ loop.index }}" class="h-56 w-full object-cover">
                        </figure>
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    </section>
{% endblock %}
