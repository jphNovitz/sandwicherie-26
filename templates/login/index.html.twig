{# templates/login/index.html.twig #}
{% extends 'base.html.twig' %}


{% block body %}
    <div class="mx-auto my-10 max-w-xl">
        <div class="overflow-hidden rounded-[2rem] border border-base-300 bg-base-100/95 shadow-2xl shadow-neutral/10 backdrop-blur">
            <div class="bg-neutral px-8 py-6 text-neutral-content sm:px-10">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary-content/70">Administration</p>
                <h1 class="mt-2 text-3xl font-black sm:text-4xl">{% trans %}title.login{% endtrans %}</h1>
                <p class="mt-3 max-w-md text-sm text-neutral-content/80">
                    Connectez-vous avec votre compte pour acceder a l’espace d’administration.
                </p>
            </div>

            <div class="px-8 py-8 sm:px-10">
        {% if error %}
                <div class="alert alert-error mb-6">
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
        {% endif %}

                <form action="{{ path('app_login') }}" method="post" class="space-y-6">
                    <div class="space-y-2">
                        <label for="email" class="text-sm font-semibold text-base-content">
                            {% trans %}form.email{% endtrans %}
                        </label>
                        <input
                            type="text"
                            id="email"
                            name="_username"
                            value="{{ email }}"
                            autocomplete="username"
                            class="input input-bordered w-full border-base-300 bg-base-200 text-base-content placeholder:text-base-content/50 focus:border-primary focus:outline-none"
                        >
                    </div>

                    <div class="space-y-2">
                        <label for="password" class="text-sm font-semibold text-base-content">
                            {% trans %}form.password{% endtrans %}
                        </label>
                        <input
                            type="password"
                            id="password"
                            name="_password"
                            autocomplete="current-password"
                            class="input input-bordered w-full border-base-300 bg-base-200 text-base-content placeholder:text-base-content/50 focus:border-primary focus:outline-none"
                        >
                    </div>

                    {# If you want to control the URL the user is redirected to on success
                <input type="hidden" name="_target_path" value="/account"> #}

                    <button type="submit" class="btn btn-primary btn-lg w-full rounded-xl text-base font-bold shadow-lg shadow-primary/20">
                        {% trans %}button.login{% endtrans %}
                    </button>
                </form>

            </div>
        </div>
    </div>
{% endblock %}
